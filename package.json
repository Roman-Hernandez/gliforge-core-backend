{
  "name": "gliforge-api",
  "version": "0.1.0",
  "private": true,
  "description": "Backend API for Gliforge, an open-core icon library management platform.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "worker:dev": "tsx watch src/jobs/worker.ts"
  },
  "dependencies": {
    "@fastify/cors": "^8.2.0",
    "@fastify/helmet": "^9.1.0",
    "@fastify/multipart": "^8.3.1",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.12.12",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "fastify": "^4.28.1",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^2.0.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "svgo": "^3.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.4",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "drizzle-kit": "^0.27.2",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.10.0",
    "pino-pretty": "^11.2.2",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.2"
  }
}
